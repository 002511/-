# Dependencies and package-manager caches
node_modules/
_tools/
_tools/npm/
_tools/npm-cache/

# Build and release output
dist/
release/
test-results/
.playwright-cli/
playwright-report/

# Runtime bundles copied for local desktop packaging
FleshOut-Compatible-App/runtime/

# Local app state and generated user/project data
FleshOut-Compatible-App/data/*.db
FleshOut-Compatible-App/data/*.sqlite
FleshOut-Compatible-App/data/user-projects/
FleshOut-Compatible-App/output/
FleshOut-Compatible-App/server.log
_reverse_analysis/*.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment and secret-bearing local config
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# Original packaged app and unpacked runtime artifacts
*.exe
*.msi
*.dll
*.dylib
*.so
_unpacked/

# External cloned references and nested Git metadata
_external/
**/.git/

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
